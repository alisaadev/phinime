{
  "expo": {
    "name": "phinime",
    "slug": "phinime",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "scheme": "phinime",
    "experiments": {
      "typedRoutes": true
    },
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#1A1A29"
    },
    "android": {
      "predictiveBackGestureEnabled": false,
      "package": "com.phinime"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "@react-native-google-signin/google-signin",
      "expo-web-browser"
    ],
    "ios": {
      "bundleIdentifier": "com.phinime"
    }
  }
}
